            </div>
            <div class="contact-meta">
              <span class="contact-meta-label">Languages</span>
              <span class="contact-meta-value">English</span>
            </div>
          </div>
        </div>

        <div class="contact-form">
          <h3>Tell me about your project.</h3>
          <p class="contact-form-sub">A few details. I'll come back with the right next step.</p>
          <form>
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" required />
            </div>
            <div class="form-group">
              <label>Project stage</label>
              <div class="radio-row">
                <label><input type="radio" name="stage" value="planning" required />Planning</label>
                <label><input type="radio" name="stage" value="building" />Building</label>
                <label><input type="radio" name="stage" value="operating" />Operating</label>
                <label><input type="radio" name="stage" value="improving" />Improving</label>
              </div>
            </div>
            <div class="form-group">
              <label for="message">Brief description</label>
              <textarea id="message" name="message" placeholder="One or two lines about your project." required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Project Details</button>
          </form>
        </div>
      </div>
    </div>
